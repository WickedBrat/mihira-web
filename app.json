{
  "expo": {
    "name": "Mihira",
    "slug": "mihira",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "mihira",
    "userInterfaceStyle": "dark",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0e0e0e"
    },
    "ios": {
      "bundleIdentifier": "com.mihira.app",
      "buildNumber": "1",
      "supportsTablet": false
    },
    "android": {
      "package": "com.mihira.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0e0e0e"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "server"
    },
    "plugins": [
      "expo-router",
      [
        "expo-font",
        {
          "fonts": [
            "./node_modules/@expo-google-fonts/google-sans/400Regular/GoogleSans_400Regular.ttf",
            "./node_modules/@expo-google-fonts/google-sans/500Medium/GoogleSans_500Medium.ttf",
            "./node_modules/@expo-google-fonts/google-sans/600SemiBold/GoogleSans_600SemiBold.ttf",
            "./node_modules/@expo-google-fonts/google-sans/700Bold/GoogleSans_700Bold.ttf"
          ]
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-secure-store",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "posthogProjectToken": "${POSTHOG_PROJECT_TOKEN}",
      "posthogHost": "${POSTHOG_HOST}",
      "enableDevButtons": "${ENABLE_DEV_BUTTONS}"
    }
  }
}
