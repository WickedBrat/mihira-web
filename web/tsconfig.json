{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "dom",
      "dom.iterable",
      "es2022"
    ],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": ".",
    "paths": {
      "@supabase/*": [
        "./node_modules/@supabase/*"
      ],
      "@/features/*": [
        "../mobile/features/*"
      ],
      "@/lib/ai/*": [
        "../mobile/lib/ai/*"
      ],
      "@/lib/dailyAlignmentTypes": [
        "../mobile/lib/dailyAlignmentTypes.ts"
      ],
      "@/lib/dailyArthReflectionTypes": [
        "../mobile/lib/dailyArthReflectionTypes.ts"
      ],
      "@/lib/vedic/*": [
        "../mobile/lib/vedic/*"
      ],
      "@/*": [
        "./*",
        "../*"
      ]
    },
    "esModuleInterop": true
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
